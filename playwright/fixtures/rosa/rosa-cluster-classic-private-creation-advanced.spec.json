{
  "rosa-classic-private-advanced": {
    "ClusterNamePrefix": "play-rosa-classic-pvt-adv",
    "ControlPlaneType": "Classic architecture",
    "Type": "ROSA",
    "Region": "us-west-2, US West, Oregon",
    "Availability": "Multi-zone",
    "AdditionalEncryption": "Enabled",
    "FIPSCryptography": "Enabled",
    "ClusterAutoscaling": "Enabled",
    "UserWorkloadMonitoring": "Enabled",
    "InstanceMetadataService": "IMDSv2 only",
    "RootDiskSize": "350",
    "ClusterPrivacy": "Private",
    "MachineCIDR": "10.0.0.0/16",
    "ServiceCIDR": "172.30.0.0/16",
    "PodCIDR": "10.128.0.0/14",
    "HostPrefix": "23",
    "InstallIntoExistingVPC": "Enabled",
    "OidcProviderMode": "auto",
    "ApplicationIngress": "Custom settings",
    "RouteSelector": "roas=advanced,profile=testing",
    "ExcludedNamespaces": "multizone,private,autoscale",
    "NamespaceOwnershipPolicy": "Strict",
    "WildcardPolicy": "Disallowed",
    "UpdateStrategy": "Recurring updates",
    "NodeDrainingGracePeriod": "30 minutes",
    "MachinePools": [
      {
        "Name": "worker",
        "InstanceType": "m6id.xlarge",
        "Autoscaling": "Enabled",
        "MinimumNodeCount": "2",
        "MaximumNodeCount": "3",
        "NodeLabels": [
          {
            "Key": "name",
            "Value": "play-rosa-advanced-private-custom-profile"
          }
        ]
      }
    ]
  }
}
